# ============================================================
# ProctoLearn — Main .env (dev/local)
# Copy this file and fill in real secrets before running.
# NEVER commit real credentials to git.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=proctolearn
POSTGRES_PASSWORD=proctolearn_pass
POSTGRES_DB=proctolearn_db

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_pass

# --- JWT ---
JWT_SECRET=super_secret_jwt_key_change_me
JWT_EXPIRES_IN=7d

# --- App URLs ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Email (Mailpit for dev) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@proctolearn.local

# --- n8n integration ---
N8N_EXAM_SUBMIT_WEBHOOK_URL=http://n8n:5678/webhook/proctolearn/exam-submit
N8N_WEBHOOK_TOKEN=change_me_n8n_token

# --- n8n admin ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_ENCRYPTION_KEY=proctolearn_n8n_encryption_key

# --- Jenkins ---
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin123
JENKINS_ADMIN_EMAIL=admin@proctolearn.com

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@proctolearn.com
PGADMIN_DEFAULT_PASSWORD=admin123

# --- OPAL ---
OPAL_MASTER_TOKEN=proctolearn-opal-token
OPAL_POLICY_REPO_URL=https://github.com/AASSAA17/ProctoLearn
OPAL_POLICY_REPO_POLLING_INTERVAL=20
OPAL_CLIENT_TOKEN=proctolearn-opal-token
