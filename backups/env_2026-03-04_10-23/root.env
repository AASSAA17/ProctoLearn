# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=proctolearn_db

# Database URL (overridden in Docker via docker-compose environment)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/proctolearn_db

# JWT
JWT_ACCESS_SECRET=proctolearn_access_secret_2025
JWT_REFRESH_SECRET=proctolearn_refresh_secret_2025
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=proctolearn-evidence

# App
API_PORT=4000
NODE_ENV=development

# Frontend (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
