// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  PROCTOR
  ADMIN
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TEXT
}

enum AttemptStatus {
  IN_PROGRESS
  FINISHED
  FAILED
  FLAGGED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum StepType {
  VIDEO
  TEXT
  TASK
}

model User {
  id                  String                @id @default(uuid())
  name                String
  email               String                @unique
  phone               String?
  password            String
  role                Role                  @default(STUDENT)
  createdAt           DateTime              @default(now())
  lastSeen            DateTime?
  isOnline            Boolean               @default(false)
  mustChangePassword  Boolean               @default(false)
  courses             Course[]
  attempts            Attempt[]
  certificates        Certificate[]
  refreshToken        String?
  lessonProgress      LessonProgress[]
  passwordResetTokens PasswordResetToken[]
  enrollments         Enrollment[]
  submissions         Submission[]

  @@map("users")
}

model LessonProgress {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  lessonId  String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Course {
  id              String           @id @default(uuid())
  title           String
  description     String?
  teacherId       String
  level           CourseLevel      @default(BEGINNER)
  teacher         User             @relation(fields: [teacherId], references: [id])
  lessons         Lesson[]
  modules         CourseModule[]
  exams           Exam[]
  certificates    Certificate[]
  lessonProgress  LessonProgress[]
  enrollments     Enrollment[]
  createdAt       DateTime         @default(now())

  @@map("courses")
}

model Enrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  completedAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Lesson {
  id             String           @id @default(uuid())
  courseId       String?
  moduleId       String?
  title          String
  content          String
  videoUrl         String?
  assignment       String?
  assignmentAnswer String?
  order            Int
  course         Course?          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module         CourseModule?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
  steps          Step[]
  createdAt      DateTime         @default(now())

  @@map("lessons")
}

model CourseModule {
  id       String   @id @default(uuid())
  title    String
  order    Int
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
  createdAt DateTime @default(now())

  @@map("course_modules")
}

model Step {
  id          String       @id @default(uuid())
  type        StepType
  order       Int
  content     Json
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions Submission[]
  createdAt   DateTime     @default(now())

  @@map("steps")
}

model Submission {
  id        String   @id @default(uuid())
  stepId    String
  userId    String
  answer    Json
  isCorrect Boolean
  score     Int
  createdAt DateTime @default(now())
  step      Step     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, stepId])
  @@map("submissions")
}

model Exam {
  id        String     @id @default(uuid())
  courseId  String
  title     String
  duration  Int
  passScore Int        @default(60)
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  Attempt[]
  createdAt DateTime   @default(now())

  @@map("exams")
}

model Question {
  id      String       @id @default(uuid())
  examId  String
  text    String
  type    QuestionType
  options Json?
  answer  String
  exam    Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("questions")
}

model Attempt {
  id         String        @id @default(uuid())
  examId     String
  userId     String
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  score      Int?
  trustScore Int           @default(100)
  status     AttemptStatus @default(IN_PROGRESS)
  exam       Exam          @relation(fields: [examId], references: [id])
  user       User          @relation(fields: [userId], references: [id])
  events     ProctorEvent[]
  evidences  EvidenceFile[]
  answers    Answer[]

  @@index([examId, userId])
  @@map("attempts")
}

model Answer {
  id         String   @id @default(uuid())
  attemptId  String
  questionId String
  answer     String
  isCorrect  Boolean?
  attempt   Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id])

  @@index([attemptId])
  @@map("answers")
}

model ProctorEvent {
  id        String   @id @default(uuid())
  attemptId String
  type      String
  timestamp DateTime @default(now())
  metadata  Json?
  attempt   Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@map("proctor_events")
}

model EvidenceFile {
  id        String   @id @default(uuid())
  attemptId String
  type      String
  url       String
  createdAt DateTime @default(now())
  attempt   Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("evidence_files")
}

model Certificate {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  issuedAt DateTime @default(now())
  qrCode   String   @unique
  user     User     @relation(fields: [userId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])

  @@map("certificates")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
