# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=proctolearn_db

# Database URL (overridden in Docker via docker-compose environment)
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/proctolearn_db

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=proctolearn-evidence

# App
API_PORT=4000
NODE_ENV=development

# Demo UI credentials
PGADMIN_DEFAULT_EMAIL=admin@proctolearn.com
PGADMIN_DEFAULT_PASSWORD=1234
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_ENCRYPTION_KEY=proctolearn_n8n_encryption_key
N8N_PUBLIC_WEBHOOK_URL=http://localhost:5678/
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_EMAIL=admin@proctolearn.com
JENKINS_ADMIN_PASSWORD=admin123

# OPAL / OPA tokens
OPAL_MASTER_TOKEN=proctolearn-opal-token
OPAL_CLIENT_TOKEN=proctolearn-opal-token
OPAL_POLICY_REPO_URL=https://github.com/AASSAA17/ProctoLearn
OPAL_POLICY_REPO_POLLING_INTERVAL=20

# n8n integration (exam submit webhook)
N8N_EXAM_SUBMIT_WEBHOOK_URL=http://localhost:5678/webhook/proctolearn/exam-submit
N8N_WEBHOOK_TOKEN=change_me
SMTP_FROM=no-reply@proctolearn.kz
PROCTOR_ALERT_EMAIL=proctor@test.local

# Frontend (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
